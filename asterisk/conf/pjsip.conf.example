[transport-tcp]
type=transport
protocol=tcp
bind=0.0.0.0
external_media_address=YOUR_SERVER_IP
external_signaling_address=YOUR_SERVER_IP
local_net=YOUR_LOCAL_SUBNET/24

[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0
external_media_address=YOUR_SERVER_IP
external_signaling_address=YOUR_SERVER_IP
local_net=YOUR_LOCAL_SUBNET/24

[endpoint-template](!)
type=endpoint
transport=transport-udp
context=demo
disallow=all
allow=ulaw,alaw
direct_media=no
force_rport=no
rewrite_contact=yes
rtp_symmetric=yes

[transport-wss]
type=transport
protocol=wss
bind=0.0.0.0
external_media_address=YOUR_SERVER_IP
external_signaling_address=YOUR_SERVER_IP
local_net=YOUR_LOCAL_SUBNET/24

[webrtc-template](!)
type=endpoint
transport=transport-wss
webrtc=yes
context=demo
message_context=avr-message-context
subscribe_context=avr-subscribe-context
allow_subscribe=yes
device_state_busy_at=1
disallow=all
allow=ulaw,alaw,vp9,vp8,h264

[1000](endpoint-template)
auth=1000
aors=1000

[1000]
type=auth
auth_type=userpass
password=1000
username=1000

[1000]
type=aor
max_contacts=10

[2000](webrtc-template)
auth=2000
aors=2000

[2000]
type=auth
auth_type=userpass
password=2000
username=2000

[2000]
type=aor
max_contacts=10

; ========== IPHOST SIP TRUNK ==========
; Configure your SIP trunk settings below

[udp-5080]
type=transport
protocol=udp
bind=0.0.0.0:5080
external_media_address=YOUR_SERVER_IP
external_signaling_address=YOUR_SERVER_IP
local_net=YOUR_LOCAL_SUBNET/24

[iphost-registration]
type=registration
outbound_auth=iphost-auth
server_uri=sip:tel.iphost.md:5080
client_uri=sip:YOUR_DID@tel.iphost.md:5080
outbound_proxy=sip:sipbalancer-1.iphost.md:5080\;lr
retry_interval=60
forbidden_retry_interval=600
expiration=3600

[iphost-auth]
type=auth
auth_type=userpass
username=YOUR_DID
password=YOUR_PASSWORD

[iphost-aor]
contact=sip:sipbalancer-1.iphost.md:5080
type=aor
outbound_proxy=sip:sipbalancer-1.iphost.md:5080\;lr
max_contacts=2

[iphost-endpoint]
type=endpoint
transport=udp-5080
outbound_auth=iphost-auth
aors=iphost-aor
context=from-pstn
disallow=all
allow=ulaw,alaw
from_user=YOUR_DID
from_domain=tel.iphost.md
outbound_proxy=sip:sipbalancer-1.iphost.md:5080\;lr
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes
direct_media=no
ice_support=no
media_use_received_transport=yes

[iphost-identify]
type=identify
endpoint=iphost-endpoint
match=185.181.228.0/24
